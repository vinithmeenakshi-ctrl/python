s = input()

stack = []

match = {
    ')': '(',
    ']': '[',
    '}': '{'
}

ok = True

for ch in s:

    if ch in "([{":
        stack.append(ch)

    else:
        if not stack or stack.pop() != match[ch]:
            ok = False
            break

if ok and not stack:
    print(True)
else:
    print(False)
